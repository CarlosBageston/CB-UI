{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist/types",
    "outDir": "./dist",
    "noEmit": false
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.stories.tsx",
    "src/stories",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/setupTests.ts",
    ".storybook"
  ]
}
